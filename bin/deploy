#!/usr/bin/env bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"
VERSION=$(cat $SCRIPT_DIR/../VERSION)

docker buildx create --use --name swap_builder

docker buildx --builder=swap_builder build \
    -t reg.hcpss.org/schoolswap/web:${VERSION} \
    -t reg.hcpss.org/schoolswap/web:latest \
    --platform=linux/arm64,linux/amd64 \
    -f docker/web/Dockerfile \
    --target=app \
    --push .

docker buildx --builder=swap_builder build \
    -t reg.hcpss.org/schoolswap/nginx:${VERSION} \
    -t reg.hcpss.org/schoolswap/nginx:latest \
    --platform=linux/arm64,linux/amd64 \
    -f docker/web/Dockerfile \
    --target=nginx \
    --push .

docker buildx rm swap_builder
